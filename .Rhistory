# ETF 动量+波动率 回测策略 + 基准对比
# ===============================
# 加载必要的库
library(quantmod)
library(PerformanceAnalytics)
library(TTR)
library(dplyr)
library(zoo)
# -------------------------------
# 参数设置
# -------------------------------
initial_capital <- 1000000  # 初始资金100万
start_date <- "2018-01-01"
end_date <- "2025-08-31"
lookback_period <- 20  # 动量计算周期（20个交易日）
# 定义ETF代码（A股市场）
etf_symbols <- c("513100.SS", "510300.SS", "518880.SS")
names(etf_symbols) <- c("NAS_ETF", "HS300_ETF", "GOLD_ETF")
# -------------------------------
# 获取价格数据
# -------------------------------
tryCatch({
getSymbols(etf_symbols, from = start_date, to = end_date, src = "yahoo")
}, error = function(e) {
stop("获取数据失败，请检查ETF代码或网络连接。")
})
# 合并收盘价
prices_list <- lapply(etf_symbols, function(x) Cl(get(x)))
all_prices <- do.call(merge, prices_list)
colnames(all_prices) <- names(etf_symbols)
all_prices <- na.omit(all_prices)
# 转换为data.frame
prices_df <- as.data.frame(all_prices)
prices_df$date <- as.Date(rownames(prices_df))
# -------------------------------
# 计算收益率、动量、波动率
# -------------------------------
data_with_metrics <- prices_df %>%
arrange(date) %>%
mutate(
NAS_ETF_returns = (NAS_ETF / lag(NAS_ETF, 1)) - 1,
HS300_ETF_returns = (HS300_ETF / lag(HS300_ETF, 1)) - 1,
GOLD_ETF_returns = (GOLD_ETF / lag(GOLD_ETF, 1)) - 1
) %>%
na.omit() %>%
mutate(
NAS_ETF_momentum = runMean(NAS_ETF_returns, n = lookback_period) * 252,
HS300_ETF_momentum = runMean(HS300_ETF_returns, n = lookback_period) * 252,
GOLD_ETF_momentum = runMean(GOLD_ETF_returns, n = lookback_period) * 252,
NAS_ETF_vol = runSD(NAS_ETF_returns, n = lookback_period) * sqrt(252),
HS300_ETF_vol = runSD(HS300_ETF_returns, n = lookback_period) * sqrt(252),
GOLD_ETF_vol = runSD(GOLD_ETF_returns, n = lookback_period) * sqrt(252)
) %>%
na.omit() %>%
mutate(
NAS_ETF_risk_adj_momentum = NAS_ETF_momentum / NAS_ETF_vol,
