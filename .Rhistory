# 策略作为基准，其他ETF相对策略表现
chart.RelativePerformance(
net_value_xts[, c("NAS_ETF_NetValue", "HS300_ETF_NetValue", "GOLD_ETF_NetValue")],
benchmark = net_value_xts$Strategy_NetValue,
