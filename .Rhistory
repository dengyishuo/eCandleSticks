ret[is.na(ret)] <- 0
strategy_ret <- ret * signal
strategy_value <- cumprod(1 + strategy_ret)
# -------------------------------
# 生存分析：持仓时长
# -------------------------------
holding_periods <- rle(signal)
# ===========================
# 生存分析 + 净值曲线对比
# ===========================
library(quantmod)
library(PerformanceAnalytics)
library(TTR)
library(dplyr)
library(survival)
library(survminer)
# -------------------------------
# 获取数据（纳斯达克、沪深300、黄金ETF）
# -------------------------------
symbols <- c("QQQ", "510300.SS", "GLD")  # 纳指ETF、沪深300ETF、黄金ETF
getSymbols(symbols, from = "2018-01-01", src = "yahoo")
# 整理收盘价
all_prices <- na.omit(merge(Cl(QQQ), Cl(`510300.SS`), Cl(GLD)))
colnames(all_prices) <- c("NAS_ETF", "HS300_ETF", "GOLD_ETF")
# -------------------------------
# 策略示例（用MA交叉）
# -------------------------------
prices <- Cl(QQQ)
fast_ma <- SMA(prices, 20)
slow_ma <- SMA(prices, 60)
signal <- ifelse(fast_ma > slow_ma, 1, 0)
signal <- lag(signal, 1)  # 避免未来函数
signal[is.na(signal)] <- 0
# 策略净值
ret <- ROC(prices, type = "discrete")
ret[is.na(ret)] <- 0
strategy_ret <- ret * signal
strategy_value <- cumprod(1 + strategy_ret)
# -------------------------------
# 生存分析：持仓时长
# -------------------------------
holding_periods <- rle(as.vector(signal))   # ⚠️ 转为普通向量
durations <- holding_periods$lengths[holding_periods$values == 1]
# 生成生存分析数据框
surv_data <- data.frame(
time = durations,
status = rep(1, length(durations))
)
# 拟合生存曲线
fit <- survfit(Surv(time, status) ~ 1, data = surv_data)
# 绘制生存曲线
ggsurvplot(
fit,
conf.int = TRUE,
risk.table = TRUE,
title = "策略持仓生存分析",
xlab = "持仓天数",
ylab = "持仓存活率"
)
# -------------------------------
# 策略 vs 基准净值曲线
# -------------------------------
benchmark_returns <- ROC(all_prices, type = "discrete")
benchmark_returns <- na.omit(benchmark_returns)
benchmark_values <- apply(1 + benchmark_returns, 2, cumprod)
benchmark_values_xts <- xts(benchmark_values, order.by = index(benchmark_returns))
strategy_value_xts <- xts(strategy_value, order.by = index(prices))
strategy_value_xts <- strategy_value_xts[index(benchmark_values_xts)]  # 日期对齐
# 合并
net_value_comparison <- merge(
strategy_value_xts,
benchmark_values_xts,
join = "inner"
)
colnames(net_value_comparison) <- c("Strategy", "NAS_ETF", "HS300_ETF", "GOLD_ETF")
# 清理异常值
net_value_comparison <- na.omit(net_value_comparison)
net_value_comparison <- net_value_comparison[apply(is.finite(net_value_comparison), 1, all), ]
# 绘制净值曲线
chart.CumReturns(
net_value_comparison,
wealth.index = TRUE, legend.loc = "topleft",
main = "策略 vs 纳斯达克ETF vs 沪深300ETF vs 黄金ETF"
)
# ===============================
# ETF 动量+波动率 回测策略 + 基准对比
# ===============================
# 加载必要的库
library(quantmod)
library(PerformanceAnalytics)
library(TTR)
library(dplyr)
library(zoo)
# -------------------------------
# 参数设置
# -------------------------------
initial_capital <- 1000000  # 初始资金100万
start_date <- "2018-01-01"
end_date <- "2025-08-31"
lookback_period <- 20  # 动量计算周期（20个交易日）
# 定义ETF代码（A股市场）
etf_symbols <- c("513100.SS", "510300.SS", "518880.SS")
names(etf_symbols) <- c("NAS_ETF", "HS300_ETF", "GOLD_ETF")
# -------------------------------
# 获取价格数据
# -------------------------------
tryCatch({
getSymbols(etf_symbols, from = start_date, to = end_date, src = "yahoo")
}, error = function(e) {
stop("获取数据失败，请检查ETF代码或网络连接。")
})
# 合并收盘价
prices_list <- lapply(etf_symbols, function(x) Cl(get(x)))
all_prices <- do.call(merge, prices_list)
colnames(all_prices) <- names(etf_symbols)
all_prices <- na.omit(all_prices)
# 转换为data.frame
prices_df <- as.data.frame(all_prices)
prices_df$date <- as.Date(rownames(prices_df))
# -------------------------------
# 计算收益率、动量、波动率
# -------------------------------
data_with_metrics <- prices_df %>%
arrange(date) %>%
mutate(
NAS_ETF_returns = (NAS_ETF / lag(NAS_ETF, 1)) - 1,
HS300_ETF_returns = (HS300_ETF / lag(HS300_ETF, 1)) - 1,
GOLD_ETF_returns = (GOLD_ETF / lag(GOLD_ETF, 1)) - 1
) %>%
na.omit() %>%
mutate(
# 20日动量 (移动平均收益率 * 252，年化)
NAS_ETF_momentum = runMean(NAS_ETF_returns, n = lookback_period) * 252,
HS300_ETF_momentum = runMean(HS300_ETF_returns, n = lookback_period) * 252,
GOLD_ETF_momentum = runMean(GOLD_ETF_returns, n = lookback_period) * 252,
# 20日波动率 (标准差 * sqrt(252)，年化)
NAS_ETF_vol = runSD(NAS_ETF_returns, n = lookback_period) * sqrt(252),
HS300_ETF_vol = runSD(HS300_ETF_returns, n = lookback_period) * sqrt(252),
GOLD_ETF_vol = runSD(GOLD_ETF_returns, n = lookback_period) * sqrt(252)
) %>%
na.omit() %>%
mutate(
# 风险调整后的动量
NAS_ETF_risk_adj_momentum = NAS_ETF_momentum / NAS_ETF_vol,
HS300_ETF_risk_adj_momentum = HS300_ETF_momentum / HS300_ETF_vol,
GOLD_ETF_risk_adj_momentum = GOLD_ETF_momentum / GOLD_ETF_vol
)
# -------------------------------
# 动态权重分配
# -------------------------------
data_with_metrics <- data_with_metrics %>%
rowwise() %>%
mutate(
# 动量小于0的资产记为0
total_momenta = sum(
max(NAS_ETF_risk_adj_momentum, 0),
max(HS300_ETF_risk_adj_momentum, 0),
max(GOLD_ETF_risk_adj_momentum, 0)
),
NAS_ETF_weight = ifelse(total_momenta > 0, max(NAS_ETF_risk_adj_momentum, 0) / total_momenta, 0),
HS300_ETF_weight = ifelse(total_momenta > 0, max(HS300_ETF_risk_adj_momentum, 0) / total_momenta, 0),
GOLD_ETF_weight = ifelse(total_momenta > 0, max(GOLD_ETF_risk_adj_momentum, 0) / total_momenta, 0)
) %>%
ungroup()
# -------------------------------
# 计算组合收益
# -------------------------------
data_with_metrics <- data_with_metrics %>%
mutate(
portfolio_return = NAS_ETF_weight * NAS_ETF_returns +
HS300_ETF_weight * HS300_ETF_returns +
GOLD_ETF_weight * GOLD_ETF_returns,
portfolio_value = initial_capital * cumprod(1 + portfolio_return)
)
# -------------------------------
# 基准：沪深300 指数表现
# -------------------------------
benchmark_prices <- all_prices$HS300_ETF
benchmark_returns <- ROC(benchmark_prices, type = "discrete")
benchmark_returns <- na.omit(benchmark_returns)
benchmark_value <- initial_capital * cumprod(1 + benchmark_returns)
# -------------------------------
# 绘制回测结果对比
# -------------------------------
# 转换为 xts 格式
portfolio_xts <- xts(data_with_metrics$portfolio_return, order.by = data_with_metrics$date)
colnames(portfolio_xts) <- "Strategy"
benchmark_xts <- xts(benchmark_returns, order.by = index(benchmark_returns))
colnames(benchmark_xts) <- "HS300"
# 合并对比
comparison <- merge(portfolio_xts, benchmark_xts, join = "inner")
# 画收益率对比图
charts.PerformanceSummary(comparison, main = "ETF 动量策略 vs 沪深300")
# 画净值曲线
portfolio_value_xts <- xts(data_with_metrics$portfolio_value, order.by = data_with_metrics$date)
benchmark_value_xts <- xts(benchmark_value, order.by = index(benchmark_value))
net_value_comparison <- merge(portfolio_value_xts, benchmark_value_xts, join = "inner")
colnames(net_value_comparison) <- c("Strategy_NetValue", "HS300_NetValue")
chart.CumReturns(comparison, wealth.index = TRUE, legend.loc = "topleft",
main = "策略净值 vs 沪深300净值")
# -------------------------------
# 输出最后净值
# -------------------------------
tail(net_value_comparison)
